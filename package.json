{
  "name": "niche-daily",
  "version": "2.0.0",
  "description": "Niche Daily - Partner-like AI WhatsApp agent with daily life, memory, and self-extending tools",
  "main": "dist/server/index.js",
  "scripts": {
    "dev:server": "ts-node-dev --respawn --transpile-only server/index.ts",
    "dev:web": "cd web && npm run dev -- -p 3001",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "build:server": "tsc",
    "build:web": "cd web && npm run build",
    "build": "npm run build:server && npm run build:web",
    "start:server": "node dist/server/index.js",
    "start:web": "cd web && npm run start -- -p 3001",
    "start": "npm run start:server",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "whatsapp",
    "memory",
    "personal-assistant",
    "partner-agent"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^6.6.0",
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "mongodb": "^6.12.0",
    "pino": "^9.6.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/qrcode-terminal": "^0.12.2",
    "concurrently": "^9.1.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  }
}
