# MongoDB
MONGODB_URI=mongodb://localhost:27017/niche-daily

# LLM / Embeddings (OpenAI-compatible gateway)
API_BASE_URL=https://api.openai.com/v1
API_KEY=your-api-key-here
API_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# WhatsApp (digits only, country code, no +)
AUTHORIZED_PHONE=6281234567890

# Server ports
# Local dev (default):
#   API Express :3000
#   Web Next    :3001  (rewrites /api -> :3000)
# Docker/Dokploy (set by compose/Dockerfile):
#   API Express :4000 (internal)
#   Web Next    :3000 (public domain)
PORT=3000
WEB_PORT=3001
API_PORT=3000
API_TOKEN=niche-daily-local

# Docker / Dokploy
# WHATSAPP_AUTH_DIR=/app/whatsapp_auth
# For compose internal mongo:
# MONGODB_URI=mongodb://mongo:27017/niche-daily
# HOST_WEB_PORT=3000

# Persona / schedule
TIMEZONE=Asia/Jakarta
ENABLE_QUIET_HOURS=true
QUIET_HOURS_START=23:30
QUIET_HOURS_END=06:30
PROACTIVE_MIN_INTERVAL_SEC=300
PROACTIVE_MAX_PER_DAY=12
PROACTIVE_MAX_OVERDUE_MIN=8
SCHEDULE_TICK_MS=30000

# Merge multipesan user bubbles before replying (seconds after last bubble)
USER_BUBBLE_DEBOUNCE_SEC=120

# Memory
MEMORY_IMPORTANCE_THRESHOLD=0.7
MEMORY_RETRIEVAL_LIMIT=5
HISTORY_MAX_MESSAGES=24

# WhatsApp auth folder
WHATSAPP_AUTH_DIR=whatsapp_auth
