# MongoDB
MONGODB_URI=mongodb://localhost:27017/niche-daily

# LLM / Embeddings (OpenAI-compatible gateway)
API_BASE_URL=https://api.openai.com/v1
API_KEY=your-api-key-here
API_MODEL=gpt-4o-mini
# Vision model for WhatsApp images (OpenAI-compatible /chat/completions with image_url)
# Defaults to API_MODEL if unset. Needs a vision-capable model.
# Use a vision-capable model on your gateway (e.g. gpt-4o-mini / gpt-4o).
# If API_MODEL is text-only, set VISION_MODEL separately.
VISION_MODEL=gpt-4o-mini
ENABLE_IMAGE_UNDERSTANDING=true
MAX_IMAGE_BYTES=5242880
EMBEDDING_MODEL=text-embedding-3-small

# Web search bot (Playwright Firefox). Google CAPTCHA is common on VPS IPs.
# Default skips Google-first for reliability: bing → ddg → google
SEARCH_ENGINES=bing,ddg,google
# If you have residential proxy / less CAPTCHA:
# SEARCH_ENGINES=google,bing,ddg

# WhatsApp (digits only, country code, no +)
AUTHORIZED_PHONE=6281234567890

# Server ports
# Local dev (default):
#   API Express :3000
#   Web Next    :3001  (rewrites /api -> :3000)
# Docker/Dokploy (set by compose/Dockerfile):
#   API Express :4000 (internal)
#   Web Next    :3000 (public domain)
PORT=3000
WEB_PORT=3001
API_PORT=3000
API_TOKEN=niche-daily-local

# Docker / Dokploy
# WHATSAPP_AUTH_DIR=/app/whatsapp_auth
# For compose internal mongo:
# MONGODB_URI=mongodb://mongo:27017/niche-daily
# HOST_WEB_PORT=3000

# Persona / schedule
TIMEZONE=Asia/Jakarta
ENABLE_QUIET_HOURS=true
QUIET_HOURS_START=23:30
QUIET_HOURS_END=06:30
PROACTIVE_MIN_INTERVAL_SEC=300
PROACTIVE_MAX_PER_DAY=12
PROACTIVE_MAX_OVERDUE_MIN=8
SCHEDULE_TICK_MS=30000

# Merge multipesan user bubbles before replying (seconds after last bubble)
USER_BUBBLE_DEBOUNCE_SEC=120

# Memory
MEMORY_IMPORTANCE_THRESHOLD=0.7
# Realtime only stores very high importance; rest waits for nightly sleep
REALTIME_MEMORY_IMPORTANCE_THRESHOLD=0.85
MEMORY_RETRIEVAL_LIMIT=5
# Same-day working memory (full day context)
HISTORY_MAX_MESSAGES=200
DAY_HISTORY_MAX_MESSAGES=200
# Nightly "sleep": consolidate day chat → long-term memories, then clear
ENABLE_NIGHTLY_CONSOLIDATE=true
NIGHTLY_CONSOLIDATE_HOUR=0
NIGHTLY_CONSOLIDATE_MINUTE=5
# Nightly memory bank cleanup (merge near-duplicates)
ENABLE_NIGHTLY_MEMORY_HYGIENE=true
MEMORY_DEDUP_COSINE_THRESHOLD=0.9
MEMORY_DEDUP_TOKEN_OVERLAP=0.72
MEMORY_DEDUP_MAX_SCAN=250

# WhatsApp auth folder
WHATSAPP_AUTH_DIR=whatsapp_auth
